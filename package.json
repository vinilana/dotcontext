{
  "name": "@dotcontext/cli",
  "version": "1.1.1",
  "description": "A harness for your harness — the contextual layer that keeps work going across any AI tool, with CLI, MCP, and host integration surfaces",
  "main": "dist/cli/index.js",
  "exports": {
    ".": "./dist/cli/index.js",
    "./package.json": "./package.json",
    "./cli": "./dist/cli/index.js",
    "./harness": "./dist/harness/index.js",
    "./mcp": "./dist/mcp/index.js",
    "./integrations": "./dist/integrations/index.js",
    "./integrations/claude-code": "./dist/integrations/claude-code/index.js",
    "./integrations/codex": "./dist/integrations/codex/index.js",
    "./integrations/pi-dev": "./dist/integrations/pi-dev/index.js"
  },
  "bin": {
    "dotcontext": "dist/index.js"
  },
  "files": [
    "dist/**/*",
    "web-ui/dist/**/*",
    "README.md",
    "LICENSE",
    "prompts/**/*"
  ],
  "engines": {
    "node": ">=20.12.0"
  },
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && tsc",
    "dev:web": "node scripts/dev-web.js",
    "dev:web-api": "tsx src/index.ts web --api-only --no-open",
    "dev:web-ui": "npm --prefix web-ui run dev",
    "build:web-ui": "npm --prefix web-ui install && npm --prefix web-ui run build",
    "build:packages": "npm run build && npm run build:web-ui && node scripts/build-package-bundles.js",
    "smoke:packages": "node scripts/smoke-package-bundles.js",
    "release:packages": "node scripts/release-packages.js",
    "release:packages:patch": "node scripts/release-packages.js patch",
    "release:packages:minor": "node scripts/release-packages.js minor",
    "release:packages:major": "node scripts/release-packages.js major",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "prepublishOnly": "npm run build && npm run build:web-ui",
    "version": "npm run build",
    "release": "npm version patch && npm publish --access public",
    "release:minor": "npm version minor && npm publish --access public",
    "release:major": "npm version major && npm publish --access public"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vinilana/dotcontext.git"
  },
  "homepage": "https://github.com/vinilana/dotcontext#readme",
  "bugs": {
    "url": "https://github.com/vinilana/dotcontext/issues"
  },
  "keywords": [
    "cli",
    "documentation",
    "agents",
    "scaffold"
  ],
  "author": "Vinicius Lana <vini@aicoders.academy>",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/js-yaml": "^4.0.9",
    "boxen": "^5.1.2",
    "chalk": "^4.1.2",
    "chokidar": "^4.0.3",
    "cli-progress": "^3.12.0",
    "commander": "^14.0.1",
    "fs-extra": "^11.3.2",
    "glob": "^13.0.6",
    "ignore": "^7.0.5",
    "js-yaml": "^4.1.1",
    "ora": "^5.4.1",
    "semver": "^7.6.3",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.0",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.5.2",
    "@types/semver": "^7.5.8",
    "jest": "^30.1.3",
    "ts-jest": "^29.4.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2"
  },
  "optionalDependencies": {
    "tree-sitter": "^0.21.0",
    "tree-sitter-typescript": "^0.23.2"
  }
}
